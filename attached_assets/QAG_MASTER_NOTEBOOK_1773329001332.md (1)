def growth_rhs(lna, y, kasb_sign, H0=H0_QAG, Om=OM_M, kasb=KASB):
    """
    S₈ growth ODE — KASB modulation  [NewCons / B10QAG Eq.2]
    Variables: y = [D, D'] where ' = d/d(ln a)
    kasb_sign: +1 = Inhale, −1 = Exhale, 0 = ΛCDM
